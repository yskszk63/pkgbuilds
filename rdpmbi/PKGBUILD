# Maintainer: Yusuke Suzuki <yskszk63@gmail.com>

pkgname=rdpmib
pkgver=0.1.3
pkgrel=1
pkgdesc='Microsoft Identity Broker like D-Bus Service for freerdp built with WITH_SSO_MIB. '
arch=(x86_64)
url=https://github.com/yskszk63/rdpmib
license=(MIT)

depends=(dbus)
makedepends=(cargo)
source=("$url/archive/v$pkgver/$pkgname-$pkgver.tar.gz")
sha256sums=('754447b2b5a9d5ad45b15e0c10469a10bde556522ce92956f4c36d1e06812d83')

prepare() {
  cd "${pkgname}-${pkgver}"

  cargo fetch --locked
}

build() {
  cd "$pkgname-$pkgver"
  CFLAGS+=' -ffat-lto-objects'

  cargo build --release --frozen
}

check() {
  cd "$pkgname-$pkgver"

  cargo test --release --frozen
}

package() {
  cd "$pkgname-$pkgver"

  install -vDm755 -t "$pkgdir/usr/bin" target/release/rdpmib target/release/rdpmib-authcode
}
